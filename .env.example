# ─── RPC endpoint (used by sign_and_send_transaction) ─────────────────
# Defaults to https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=

# ─── Backend selector ──────────────────────────────────────────────────
# Supported values: memory | privy | turnkey | aws-kms | gcp-kms |
#                   fireblocks | dfns | vault | cdp | crossmint | openfort | para
KEYCHAIN_BACKEND=memory

# ─── memory backend ────────────────────────────────────────────────────
# Base58 private key, U8Array JSON string "[1,2,...,64]", or path to keypair file
KEYCHAIN_PRIVATE_KEY=

# ─── privy backend ─────────────────────────────────────────────────────
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_WALLET_ID=

# ─── turnkey backend ───────────────────────────────────────────────────
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
TURNKEY_ORGANIZATION_ID=
TURNKEY_PRIVATE_KEY_ID=   # Turnkey private key ID for signing
TURNKEY_PUBLIC_KEY=       # Solana public key (base58) for this private key

# ─── aws-kms backend ───────────────────────────────────────────────────
AWS_KMS_KEY_ID=           # Key ID or ARN (must be ECC_NIST_EDWARDS25519 type)
AWS_KMS_PUBLIC_KEY=       # Solana public key (base58) for this KMS key
AWS_REGION=               # Optional; falls back to AWS default region config

# ─── gcp-kms backend ───────────────────────────────────────────────────
GCP_KMS_KEY_NAME=         # Full resource name: projects/.../cryptoKeyVersions/N
GCP_KMS_PUBLIC_KEY=       # Solana public key (base58) for this KMS key

# ─── fireblocks backend ────────────────────────────────────────────────
FIREBLOCKS_API_KEY=
FIREBLOCKS_PRIVATE_KEY_PEM=   # RSA 4096 private key PEM (for JWT signing)
FIREBLOCKS_VAULT_ACCOUNT_ID=

# ─── dfns backend ──────────────────────────────────────────────────────
DFNS_AUTH_TOKEN=          # Service account or personal access token
DFNS_CRED_ID=             # Credential ID for user action signing
DFNS_PRIVATE_KEY_PEM=     # PEM private key for signing user action challenges
DFNS_WALLET_ID=

# ─── vault (HashiCorp Vault) backend ───────────────────────────────────
VAULT_ADDR=               # e.g. https://vault.example.com
VAULT_TOKEN=
VAULT_KEY_NAME=           # Transit engine key name
VAULT_PUBLIC_KEY=         # Solana public key (base58) for this transit key

# ─── cdp (Coinbase Developer Platform) backend ─────────────────────────
CDP_ADDRESS=              # Solana account address managed by CDP
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=       # Base64-encoded Ed25519 64-byte key
CDP_WALLET_SECRET=        # Base64-encoded PKCS#8 DER EC P-256 private key

# ─── crossmint backend ─────────────────────────────────────────────────
CROSSMINT_API_KEY=
CROSSMINT_WALLET_LOCATOR=

# ─── openfort backend ──────────────────────────────────────────────────
OPENFORT_ACCOUNT_ID=      # Backend wallet account ID (acc_<uuid>)
OPENFORT_SECRET_KEY=      # Project secret key (sk_test_* / sk_live_*)
OPENFORT_WALLET_SECRET=   # ECDSA P-256 PKCS#8 private key (bare base64 DER or PEM)

# ─── para backend ──────────────────────────────────────────────────────
PARA_API_KEY=
PARA_WALLET_ID=
